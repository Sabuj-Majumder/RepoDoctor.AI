# RepoDoctor AI Environment Variables

# Database URL - SQLite database location
# For local development: file:./dev.db
# For production: file:/absolute/path/to/prod.db
DATABASE_URL="file:./dev.db"

# GitHub Personal Access Token (optional but recommended)
# Increases API rate limits from 60 to 5000 requests per hour
# Create one at: https://github.com/settings/tokens
# No special scopes required for public repositories
# GITHUB_TOKEN="ghp_your_token_here"

# Ollama API URL (optional)
# Only needed if you want AI-powered analysis features
# Default: http://localhost:11434
# OLLAMA_URL="http://localhost:11434"
